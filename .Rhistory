library(nycflights13)
flights
flights |>
filter(dep_delay > 120)
flights |>
filter(month == 1)
flights |>
arrange(year, month, day, dep_time)
flights %>%
distinct(origin, dest)
flights |>
distinct(origin, dest, .keep_all = TRUE)
flights %>%  # creamos la columna gain y speed, a partir de otras columnas del tibble
mutate(
gain = dep_delay - arr_delay,
speed = distance / air_time * 60
)
flights |>
mutate(
gain = dep_delay - arr_delay,
hours = air_time / 60,
gain_per_hour = gain / hours,
.keep = "used"
)
flights %>%
select(year, month, day)
flights %>%
select(year:day)
flights |>
select(!year:day) # para no seleccionar esas
flights %>%
select(where(is.character))
flights |>
relocate(time_hour, air_time)
flights
flights %>%
group_by(month)
flights %>%
group_by(month) %>%
summarize(
avg_delay = mean(dep_delay)
)
glimpse(flights)
flights |>
group_by(month) |>
summarize(
avg_delay = mean(dep_delay, na.rm = TRUE)
)
flights %>%
#group_by(month) %>%
summarize(avg_delay = mean(dep_delay, na.rm = TRUE))
flights |>
group_by(month) |>
summarize(
avg_delay = mean(dep_delay, na.rm = TRUE),
n = n()
)
?mean
?n
?n()
flights |>
group_by(dest) |>
slice_max(arr_delay, n = 1) |>
relocate(dest)
daily %>%
ungroup()
flights %>%
ungroup()
flights |>
summarize(
delay = mean(dep_delay, na.rm = TRUE),
n = n(),
.by = month
)
install.packages("styler")
library(styler)
billboard
library(tidyverse)
billboard
billboard <- billboard
billboard |>
pivot_longer(
cols = starts_with("wk"),
names_to = "week",
values_to = "rank"
)
billboard_largo <- billboard |>
pivot_longer(
cols = starts_with("wk"),
names_to = "week",
values_to = "rank"
)
View(billboard_largo)
View(billboard)
billboard_largo <- billboard |>
pivot_longer(
cols = starts_with("wk"),
names_to = "week",
values_to = "rank",
values_drop_na = TRUE
)
billboard_largo <- billboard |>
pivot_longer(
cols = starts_with("wk"),
names_to = "week",
values_to = "rank",
values_drop_na = TRUE
) |>
mutate(
week = parse_number(week)
)
who2
who2 <- who2
who2 |>
pivot_longer(
cols = !(country:year),
names_to = c("diagnosis", "gender", "age"),
names_sep = "_",
values_to = "count"
)
who2_pivoteado <- who2 |>
pivot_longer(
cols = !(country:year),
names_to = c("diagnosis", "gender", "age"),
names_sep = "_",
values_to = "count"
)
View(who2)
View(who2_pivoteado)
View(who2)
cms_patient_experience
cms_patient_experience <- cms_patient_experience
View(billboard)
View(billboard_largo)
billboard_ancho <- billboard_largo %>%
pivot_wider(names_from = "week",
values_from = "rank"
)
View(billboard_ancho)
billboard_ancho <- billboard_largo %>%
pivot_wider(names_from = "week",
values_from = "rank",
names_prefix = "wk"
)
